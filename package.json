{
  "name": "btcr2-aggregation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Public example app: end-to-end web-based did:btcr2 aggregation over the HTTP/REST transport.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "tsc -b",
    "test": "tsc -b && vitest run",
    "e2e": "tsc -b && tsx e2e/headless-cohort.ts",
    "e2e:smt": "tsc -b && tsx e2e/headless-cohort.ts --smt",
    "e2e:x1": "tsc -b && tsx e2e/headless-cohort.ts --x1",
    "e2e:mixed": "tsc -b && tsx e2e/headless-cohort.ts --mixed",
    "e2e:x1:negative": "tsc -b && tsx e2e/headless-cohort.ts --negative",
    "e2e:operator": "tsc -b && tsx e2e/operator-cohort.ts",
    "e2e:browse": "tsc -b && tsx e2e/browse-join-cohort.ts",
    "e2e:persist": "tsc -b && tsx e2e/persist-cohort.ts",
    "e2e:resolve": "tsc -b && tsx e2e/resolve-cohort.ts",
    "e2e:config": "tsc -b && tsx e2e/config.ts",
    "e2e:ipfs": "tsc -b && tsx e2e/ipfs-cohort.ts",
    "e2e:baked": "tsc -b && tsx e2e/baked-cohort.ts",
    "e2e:live:mock": "tsc -b && tsx e2e/live-mock-cohort.ts",
    "e2e:live:broadcast": "tsc -b && tsx e2e/live-broadcast-cohort.ts",
    "e2e:live:regtest": "tsc -b && LIVE=1 LIVE_NETWORK=regtest tsx e2e/resolve-cohort.ts",
    "e2e:browser": "pnpm -r build && tsx e2e/browser-cohort.ts",
    "e2e:browser:prod": "pnpm -r build && tsx e2e/browser-prod-cohort.ts",
    "dev": "pnpm --filter @btcr2-aggregation/web dev",
    "demo": "pnpm -r build && tsx packages/service/src/demo-server.ts",
    "lint": "eslint .",
    "clean": "rimraf 'packages/*/dist' 'e2e/dist' tsconfig.tsbuildinfo 'packages/*/tsconfig.tsbuildinfo' 'e2e/tsconfig.tsbuildinfo'"
  },
  "devDependencies": {
    "@types/node": "^22",
    "eslint": "^9",
    "rimraf": "^6",
    "tsx": "^4",
    "typescript": "^5.9",
    "typescript-eslint": "^8",
    "vitest": "^2"
  }
}
